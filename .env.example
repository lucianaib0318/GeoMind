# Tencent Location Service key. Do not commit your real key.
TENCENT_MAP_KEY=your-tencent-map-key

# Optional: override geocode cache path.
GEOMIND_GEOCODE_CACHE=cache/geocode-cache.json

# Optional: timeout for Tencent geocoder calls.
GEOMIND_GEOCODE_TIMEOUT_MS=8000

# Feishu CLI adapter command.
# The command must print either plain text or JSON containing text/content/markdown/blocks.
# Placeholders are shell-quoted by GeoMind: {url}, {token}, {kind}
#
# Recommended MVP command:
FEISHU_CLI_COMMAND_TEMPLATE=lark-cli docs +fetch --doc {url} --api-version v2 --format json
